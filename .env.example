# Novahiz OS — Environment Variables
# Copy to ~/.novahiz/.env and fill in your keys
# chmod 600 ~/.novahiz/.env

# --- REQUIRED ---
# OpenRouter API key (get one at https://openrouter.ai/keys)
OPENROUTER_API_KEY=sk-or-v1-your-key-here

# --- OPTIONAL ---
# OpenCode Zen API key (get one at https://opencode.ai)
OPENCODE_ZEN_API_KEY=

# Supabase access token (for Supabase MCP)
SUPABASE_ACCESS_TOKEN=

# GitHub personal access token (for GitHub MCP)
# Scopes: repo, workflow, read:org
GITHUB_TOKEN=
