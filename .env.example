# Novahiz OS — Environment Variables
# Copy to ~/.novahiz/.env and fill in your keys
# chmod 600 ~/.novahiz/.env

# --- REQUIRED ---
# OpenRouter API key (get one at https://openrouter.ai/keys)
OPENROUTER_API_KEY=sk-or-v1-your-key-here

# --- OPTIONAL ---
# OpenCode Zen API key (get one at https://opencode.ai)
OPENCODE_ZEN_API_KEY=

# Supabase access token (for Supabase MCP)
SUPABASE_ACCESS_TOKEN=

# GitHub personal access token (for GitHub MCP)
# Scopes: repo, workflow, read:org
GITHUB_TOKEN=

# --- MODEL CONFIGURATION (optional) ---
# Override which models each tier uses.
# Uncomment any line to override that value at every boot.
# NOVAHIZ_PREMIUM_MODEL=anthropic/claude-3-5-sonnet
# NOVAHIZ_SMART_MODEL=opencode/qwen3.5-plus
# NOVAHIZ_FLASH_MODEL=openrouter/qwen/qwen3.5-9b
# NOVAHIZ_PREMIUM_FALLBACKS=openrouter/qwen/qwen3.6-plus,opencode/qwen3.6-plus
# NOVAHIZ_SMART_FALLBACKS=openrouter/qwen/qwen3.6-flash,openrouter/qwen/qwen3.6-35b-a3b
# NOVAHIZ_FLASH_FALLBACKS=openrouter/qwen/qwen3.5-flash-02-23,openrouter/stepfun/step-3.5-flash
# NOVAHIZ_PREMIUM_BUDGET=5
# OPENCODE_DEFAULT_MODEL=anthropic/claude-3-5-sonnet
# OPENCODE_SMALL_MODEL=opencode/qwen3.5-plus
