# Novahiz OS — Git Ignore (Production Ready)

# =============================================================================
# SECRETS & CREDENTIALS (CRITICAL)
# =============================================================================
.env
*.env
**/.env
api_keys.json
secrets.json
*.key
*.pem
*.crt
private*.key
credentials.json
service-account*.json
**/gcloud-service-key.json

# GitHub token (NEVER commit)
.github-token
.github_token

# =============================================================================
# CONFIG (contains API keys)
# =============================================================================
runtime/config.json
.config/opencode/

# =============================================================================
# LOGS & PID FILES
# =============================================================================
logs/*.log
logs/*.log.*
*.log
pids/*.pid
*.pid

# =============================================================================
# PYTHON
# =============================================================================
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
*.egg-info/
.eggs/
.pytest_cache/
.coverage
htmlcov/
.tox/
.mypy_cache/
.ruff_cache/

# =============================================================================
# NODE.JS
# =============================================================================
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# =============================================================================
# IDE & EDITORS
# =============================================================================
.idea/
.vscode/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# =============================================================================
# BUILD & DIST
# =============================================================================
dist/
build/
*.egg
*.whl

# =============================================================================
# EXECUTION FILES (TEMPORARY)
# =============================================================================
executions/exec_*.json
pending_tasks/
completed_tasks/

# =============================================================================
# BACKUPS & ARCHIVES
# =============================================================================
backups/
*.backup
*.bak
*.tmp
*.tar.gz
*.zip

# =============================================================================
# CHROME PROFILE (MCP)
# =============================================================================
chrome-profile-mcp/

# =============================================================================
# OPTIONAL (USER CHOICE)
# =============================================================================

# Memory state (can be committed for sync across machines)
# memory/00_Core/metrics.json
# memory/00_Core/nexus.json

# Logs (runtime data — do NOT commit)
logs/**
!logs/logrotate.conf

# Documentation (RECOMMENDED to commit)
# docs/

# Tests (RECOMMENDED to commit)
# tests/

# Scripts (RECOMMENDED to commit)
# scripts/

# Runtime code (RECOMMENDED to commit)
# runtime/

# MCP code (RECOMMENDED to commit)
# mcp/

# =============================================================================
# =============================================================================
# LARGE BINARIES (DO NOT COMMIT — 140MB+)
# =============================================================================
bin/opencode
bin/opencode-desktop

# =============================================================================
# APPLICATION DATABASE & STATE
# =============================================================================
data/*.db
data/*.db-wal
data/*.db-shm
cache/

# =============================================================================
# NOVAHIZ ENV & INSTALL
# =============================================================================
.novahiz/
!/.env.example
install.log
