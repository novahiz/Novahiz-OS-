{
  "$schema": "https://opencode.ai/config.json",
  "default_agent": "novahiz-router",
  "model": "openrouter/qwen/qwen3.6-plus",
  "small_model": "opencode/qwen3.5-plus",
  "instructions": ["AGENTS.md"],
  "plugin": ["opencode-agent-browser"],
  "skills": {
    "paths": ["~/.opencode/skills", "~/.opencode/.agents/skills"]
  },
  "mcp": {
    "chrome-devtools": {
      "type": "local",
      "command": ["npx", "-y", "chrome-devtools-mcp@latest", "--browserUrl=http://127.0.0.1:9222", "--isolated=false", "--experimentalVision=true", "--experimentalMemory=true", "--experimentalScreencast=true", "--experimentalPageIdRouting=true", "--categoryExtensions=true", "--categoryExperimentalThirdParty=true", "--redactNetworkHeaders=true", "--no-usage-statistics"],
      "enabled": true,
      "note": "Chrome DevTools MCP — auto-connecte à Chrome 144+ via remote debugging"
    },
    "novahiz": {
      "type": "local",
      "command": ["python3", "-u", "/home/novahiz/.opencode/mcp/novahiz-mcp.py", "--mcp"],
      "enabled": true
    },
    "obsidian": {
      "type": "local",
      "command": ["npx", "-y", "@wickedevolutions/mcp-obsidian"],
      "environment": {
        "OBSIDIAN_VAULT_PATH": "/home/novahiz/Documents/llm-wiki"
      },
      "enabled": true,
      "note": "Obsidian MCP for wiki access — vault at ~/Documents/llm-wiki"
    },
    "tradingview": {
      "type": "local",
      "command": ["node", "/home/novahiz/.opencode/mcp/tradingview-mcp/versions/v1/src/server.js"],
      "enabled": true,
      "note": "Requires TradingView Desktop running with --remote-debugging-port=9222"
    },
    "google-stitch": {
      "type": "local",
      "command": ["python3", "-u", "/home/novahiz/.opencode/mcp/stitch-mcp-wrapper.py"],
      "environment": {
        "STITCH_API_KEY": "${STITCH_API_KEY}"
      },
      "enabled": true,
      "note": "Google Stitch MCP — requires STITCH_API_KEY in env"
    },
    "github": {
      "type": "http",
      "url": "https://github-mcp.local",
      "environment": {
        "GITHUB_TOKEN": "${GITHUB_TOKEN}"
      },
      "enabled": false,
      "note": "Set GITHUB_TOKEN env var and change enabled to true"
    },
    "supabase": {
      "type": "local",
      "command": ["npx", "-y", "@supabase/mcp-server-supabase@latest", "--project-ref", "nfmsyivyhsjatazhcjgu"],
      "environment": {
        "SUPABASE_ACCESS_TOKEN": "${SUPABASE_ACCESS_TOKEN}",
        "SUPABASE_DB_PASSWORD": "${SUPABASE_DB_PASSWORD}"
      },
      "enabled": true,
      "note": "Supabase MCP for project nfmsyivyhsjatazhcjgu"
    }
  },
  "tools": {
    "novahiz_route": true,
    "novahiz_auto": true,
    "novahiz_execute": true,
    "novahiz_list_agents": true,
    "novahiz_search": true,
    "novahiz_health": true
  }
}
