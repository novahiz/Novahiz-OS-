    "MEDIUM": ["build", "create", "implement", "fix", "optimize", "configure", "add", "update", "refactor", "install", "setup", "deploy"],
    "COMPLEX": ["architecture", "system", "design", "scale", "enterprise", "production", "multi", "distributed", "highload", "microservice", "pipeline"]
  },
  "agent_overrides": {}
}
