#!/bin/bash
# =============================================================================
# nv-exec — Exécute une tâche avec l'agent spécifié
# =============================================================================
# Intégration avec OpenCode subagents via le tool `task`
# =============================================================================

set -e

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
CONFIG_FILE="$SCRIPT_DIR/../config/agent-registry.json"
LOG_DIR="$SCRIPT_DIR/../logs"
LOG_FILE="$LOG_DIR/execution-$(date +%Y%m%d).log"

mkdir -p "$LOG_DIR"

# Couleurs
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
NC='\033[0m'

# =============================================================================
# LOGGING
# =============================================================================
log() {
    local timestamp=$(date '+%Y-%m-%d %H:%M:%S')
    echo "[$timestamp] $*" >> "$LOG_FILE"
}

log_info() {
    echo -e "${BLUE}[INFO]${NC} $*"
    log "INFO: $*"
}

log_success() {
    echo -e "${GREEN}[SUCCESS]${NC} $*"
    log "SUCCESS: $*"
}

log_error() {
    echo -e "${RED}[ERROR]${NC} $*" >&2
    log "ERROR: $*"
}

# =============================================================================
# VÉRIFICATION AGENT
# =============================================================================
verify_agent() {
    local agent_name="$1"
    
    if [ ! -f "$CONFIG_FILE" ]; then
        log_error "Configuration non trouvée"
        return 1
    fi
    
    local agent_exists=$(jq -r ".agents | has(\"$agent_name\")" "$CONFIG_FILE")
    
    if [ "$agent_exists" = "true" ]; then
        local agent_type=$(jq -r ".agents[\"$agent_name\"].type" "$CONFIG_FILE")
        local agent_model=$(jq -r ".agents[\"$agent_name\"].model" "$CONFIG_FILE")
        local agent_domain=$(jq -r ".agents[\"$agent_name\"].domain" "$CONFIG_FILE")
        
        echo -e "${GREEN}Agent vérifié:${NC} $agent_name"
        echo -e "  Type: $agent_type"
        echo -e "  Modèle: $agent_model"
        echo -e "  Domain: $agent_domain"
        return 0
    else
        log_error "Agent non trouvé: $agent_name"
        echo -e "${RED}Agent non trouvé: $agent_name${NC}"
        echo ""
        echo "Agents disponibles:"
        jq -r '.agents | keys[]' "$CONFIG_FILE" | sed 's/^/  - /'
        return 1
    fi
}

# =============================================================================
# EXÉCUTION AVEC SUBAGENT
# =============================================================================
execute_with_agent() {
    local agent_name="$1"
    local task="$2"
    local model=$(jq -r ".agents[\"$agent_name\"].model" "$CONFIG_FILE")
    local domain=$(jq -r ".agents[\"$agent_name\"].domain" "$CONFIG_FILE")
    
    log_info "Exécution avec $agent_name ($model)"
    
    echo ""
    echo -e "${CYAN}═══════════════════════════════════════════════════════════${NC}"
    echo -e "${CYAN}  EXÉCUTION${NC} - Agent: $agent_name"
    echo -e "${CYAN}═══════════════════════════════════════════════════════════${NC}"
    echo ""
    echo -e "${YELLOW}Tâche:${NC} $task"
    echo -e "${YELLOW}Domaine:${NC} $domain"
    echo -e "${Yellow}Modèle:${NC} $model"
    echo ""
    echo -e "${BLUE}───────────────────────────────────────────────────────────${NC}"
    echo -e "${BLUE}  RÉSULTAT${NC}"
    echo -e "${BLUE}───────────────────────────────────────────────────────────${NC}"
    echo ""
    
    # Créer un fichier temporaire pour le prompt
    local prompt_file=$(mktemp)
    cat > "$prompt_file" << PROMPT
Agis en tant que $agent_name, expert en $domain.

Tâche à exécuter:
$task

Instructions:
1. Analyse la demande
2. Fournis une réponse complète et actionnable
3. Inclus des exemples concrets si applicable
4. Termine par un résumé des points clés

Réponse:
PROMPT
    
    # Vérifier si on est dans un environnement OpenCode
    if command -v opencode &> /dev/null; then
        # Exécuter via OpenCode CLI si disponible
        log_info "Exécution via OpenCode CLI"
        opencode --agent "$agent_name" --prompt "$(cat $prompt_file)"
    else
        # Fallback: afficher le prompt pour exécution manuelle
        log_warning "OpenCode CLI non disponible - mode simulation"
        echo -e "${YELLOW}[SIMULATION]${NC} Dans un environnement OpenCode réel, la tâche serait exécutée avec:"
        echo ""
        echo "  [SUBAGENT:$agent_name]"
        echo "  Prompt: $(cat $prompt_file)"
        echo ""
        echo -e "${YELLOW}Pour exécuter manuellement:${NC}"
        echo "  1. Copier la tâche ci-dessus"
        echo "  2. Utiliser: task --subagent $agent_name --prompt \"...\""
    fi
    
    rm -f "$prompt_file"
    
    echo ""
    echo -e "${GREEN}═══════════════════════════════════════════════════════════${NC}"
    log_success "Exécution terminée avec $agent_name"
}

# =============================================================================
# USAGE
# =============================================================================
usage() {
    echo -e "${CYAN}═══════════════════════════════════════════════════════════${NC}"
    echo -e "${CYAN}  NV-EXEC${NC} - Agent Task Execution"
    echo -e "${CYAN}═══════════════════════════════════════════════════════════${NC}"
    echo ""
    echo "Usage: nv-exec <agent> <task>"
    echo ""
    echo "Arguments:"
    echo "  agent    Nom de l'agent (ex: arthur-architecture, luna-design)"
    echo "  task     Tâche à exécuter"
    echo ""
    echo "Examples:"
    echo "  nv-exec arthur-architecture \"Refactor this module\""
    echo "  nv-exec luna-design \"Create a modern dashboard UI\""
    echo "  nv-exec neo-security \"Audit this authentication flow\""
    echo ""
    echo "Commandes:"
    echo "  verify <agent>  Vérifie si un agent existe"
    echo "  list            Liste tous les agents disponibles"
    echo ""
}

# =============================================================================
# MAIN
# =============================================================================
main() {
    local command="${1:-help}"
    shift || true
    
    case "$command" in
        verify)
            if [ -z "$1" ]; then
                log_error "Agent name required"
                exit 1
            fi
            verify_agent "$1"
            ;;
        list)
            echo -e "${CYAN}Agents disponibles:${NC}"
            jq -r '.agents | to_entries[] | "\(.key) | \(.value.domain) | \(.value.type)"' "$CONFIG_FILE" | column -t -s'|'
            ;;
        *)
            # Premier argument = agent, reste = task
            local agent_name="$command"
            local task="$*"
            
            if [ -z "$task" ]; then
                log_error "Task required"
                usage
                exit 1
            fi
            
            # Vérifier l'agent
            if ! verify_agent "$agent_name"; then
                exit 1
            fi
            
            # Exécuter
            execute_with_agent "$agent_name" "$task"
            ;;
    esac
}

main "$@"
