#!/bin/bash
# =============================================================================
# nv-route — Novahiz Router: Système de routage intelligent d'agents
# =============================================================================
# Route les tâches vers les agents optimaux selon complexité et keywords
# =============================================================================

set -e

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
CONFIG_FILE="$SCRIPT_DIR/../config/agent-registry.json"
LOG_DIR="$SCRIPT_DIR/../logs"
LOG_FILE="$LOG_DIR/routing-$(date +%Y%m%d).log"

mkdir -p "$LOG_DIR"

# Couleurs
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
NC='\033[0m' # No Color

# =============================================================================
# LOGGING
# =============================================================================
log() {
    local timestamp=$(date '+%Y-%m-%d %H:%M:%S')
    echo "[$timestamp] $*" >> "$LOG_FILE"
}

log_info() {
    echo -e "${BLUE}[INFO]${NC} $*"
    log "INFO: $*"
}

log_success() {
    echo -e "${GREEN}[SUCCESS]${NC} $*"
    log "SUCCESS: $*"
}

log_warning() {
    echo -e "${YELLOW}[WARNING]${NC} $*"
    log "WARNING: $*"
}

log_error() {
    echo -e "${RED}[ERROR]${NC} $*" >&2
    log "ERROR: $*"
}

# =============================================================================
# CLASSIFICATION DE LA COMPLEXITÉ
# =============================================================================
classify_complexity() {
    local task="$1"
    local task_lower=$(echo "$task" | tr '[:upper:]' '[:lower:]')
    
    # Mots-clés COMPLEX
    if echo "$task_lower" | grep -qE '(architecture|system design|microservice|scalability|enterprise|production-ready|distributed|multi-tenant|high availability)'; then
        echo "COMPLEX"
        return
    fi
    
    # Mots-clés MEDIUM
    if echo "$task_lower" | grep -qE '(build|create|implement|develop|feature|api|database|integration|optimize|refactor|configure|setup)'; then
        echo "MEDIUM"
        return
    fi
    
    # Mots-clés SIMPLE
    if echo "$task_lower" | grep -qE '(explain|what|how|why|define|simple|quick|basic|intro|overview|list|show)'; then
        echo "SIMPLE"
        return
    fi
    
    # Par défaut: MEDIUM
    echo "MEDIUM"
}

# =============================================================================
# MATCHING DES KEYWORDS (Version améliorée avec poids)
# =============================================================================
match_keywords() {
    local task="$1"
    local agent_keywords="$2"
    local task_lower=$(echo "$task" | tr '[:upper:]' '[:lower:]')
    
    local matches=0
    local weighted_matches=0
    local total=0
    
    # Parser les keywords (format JSON array)
    local keywords=$(echo "$agent_keywords" | tr -d '[]"' | tr ',' '\n')
    
    for keyword in $keywords; do
        keyword=$(echo "$keyword" | xargs)  # trim
        [ -z "$keyword" ] && continue
        ((total++))
        
        # Match exact = 3 points, match partiel = 1 point
        if echo "$task_lower" | grep -qw "$keyword"; then
            ((matches++))
            ((weighted_matches+=3))
        elif echo "$task_lower" | grep -qi "$keyword"; then
            ((weighted_matches+=1))
        fi
    done
    
    if [ $total -eq 0 ]; then
        echo "0"
    else
        # Score pondéré avec bonus pour matches exacts
        echo "scale=2; $weighted_matches / ($total * 3)" | bc
    fi
}

# =============================================================================
# MOTEUR DE ROUTAGE
# =============================================================================
route_task() {
    local task="$1"
    local verbose="${2:-false}"
    
    log_info "Routage de la tâche: $task"
    
    # 1. Classifier la complexité
    local complexity=$(classify_complexity "$task")
    log_info "Complexité détectée: $complexity"
    
    # 2. Charger la config
    if [ ! -f "$CONFIG_FILE" ]; then
        log_error "Fichier de configuration non trouvé: $CONFIG_FILE"
        exit 1
    fi
    
    # 3. Score chaque agent
    local best_agent=""
    local best_score=0
    local best_confidence=0
    local candidates=()
    
    # Extraire la liste des agents
    local agents=$(jq -r '.agents | keys[]' "$CONFIG_FILE")
    
    for agent in $agents; do
        local agent_type=$(jq -r ".agents[\"$agent\"].type" "$CONFIG_FILE")
        local agent_priority=$(jq -r ".agents[\"$agent\"].priority" "$CONFIG_FILE")
        local agent_score=$(jq -r ".agents[\"$agent\"].score" "$CONFIG_FILE")
        local agent_keywords=$(jq -r ".agents[\"$agent\"].keywords" "$CONFIG_FILE")
        local agent_complexity=$(jq -r ".agents[\"$agent\"].complexity" "$CONFIG_FILE")
        
        # Vérifier si l'agent gère cette complexité
        if ! echo "$agent_complexity" | grep -q "$complexity"; then
            continue
        fi
        
        # Calculer le keyword match
        local keyword_score=$(match_keywords "$task" "$agent_keywords")
        
        # Calculer le score final
        # Score = (keyword_match * 0.6) + ((10 - priority) / 10 * 0.3) + (agent_score / 100 * 0.1)
        local priority_component=$(echo "scale=2; (10 - $agent_priority) / 10 * 0.3" | bc)
        local score_component=$(echo "scale=2; $agent_score / 100 * 0.1" | bc)
        local final_score=$(echo "scale=2; ($keyword_score * 0.6) + $priority_component + $score_component" | bc)
        
        # Confiance = keyword_score
        local confidence=$keyword_score
        
        if [ "$verbose" = "true" ]; then
            echo -e "  ${CYAN}$agent${NC}: keyword=$keyword_score, priority=$agent_priority, score=$agent_score => final=$final_score"
        fi
        
        # Vérifier le seuil minimum
        if (( $(echo "$confidence >= 0.4" | bc -l) )); then
            candidates+=("$agent:$final_score:$confidence")
        fi
        
        # Garder le meilleur
        if (( $(echo "$final_score > $best_score" | bc -l) )); then
            best_agent="$agent"
            best_score=$final_score
            best_confidence=$confidence
        fi
    done
    
    # 4. Décision finale
    if [ -z "$best_agent" ]; then
        log_warning "Aucun agent trouvé avec confiance suffisante"
        echo "NO_MATCH"
        return
    fi
    
    # 5. Vérifier si multi-agent nécessaire
    local multi_agent_threshold=$(jq -r '.routing_rules.multi_agent_threshold' "$CONFIG_FILE")
    local multi_agents=()
    
    for candidate in "${candidates[@]}"; do
        local cand_agent=$(echo "$candidate" | cut -d: -f1)
        local cand_confidence=$(echo "$candidate" | cut -d: -f3)
        
        if (( $(echo "$cand_confidence >= $multi_agent_threshold" | bc -l) )); then
            multi_agents+=("$cand_agent")
        fi
    done
    
    # 6. Output
    echo ""
    echo -e "${GREEN}╔════════════════════════════════════════════════════════╗${NC}"
    echo -e "${GREEN}║${NC}  ${CYAN}NOVAHIZ ROUTER${NC} - Résultat du routage"
    echo -e "${GREEN}╠════════════════════════════════════════════════════════╣${NC}"
    echo -e "${GREEN}║${NC}  Tâche: $(echo "$task" | cut -c1-50)..."
    echo -e "${GREEN}╠════════════════════════════════════════════════════════╣${NC}"
    echo -e "${GREEN}║${NC}  Complexité: ${YELLOW}$complexity${NC}"
    echo -e "${GREEN}║${NC}  Agent principal: ${GREEN}$best_agent${NC}"
    echo -e "${GREEN}║${NC}  Score: ${GREEN}$best_score${NC} (Confiance: $best_confidence)"
    
    if [ ${#multi_agents[@]} -gt 1 ]; then
        echo -e "${GREEN}║${NC}  Mode: ${YELLOW}MULTI-AGENT${NC} (${#multi_agents[@]} agents)"
        echo -e "${GREEN}║${NC}  Agents: ${CYAN}${multi_agents[*]}${NC}"
    else
        echo -e "${GREEN}║${NC}  Mode: ${BLUE}SINGLE-AGENT${NC}"
    fi
    
    echo -e "${GREEN}╠════════════════════════════════════════════════════════╣${NC}"
    echo -e "${GREEN}║${NC}  Commande d'exécution:"
    echo -e "${GREEN}║${NC}  ${YELLOW}nv exec $best_agent \"$task\"${NC}"
    echo -e "${GREEN}╚════════════════════════════════════════════════════════╝${NC}"
    echo ""
    
    # Log
    log_success "Routage terminé: $best_agent (score=$best_score, confidence=$best_confidence)"
    
    # Return l'agent pour usage programmatique
    echo "AGENT:$best_agent"
    echo "COMPLEXITY:$complexity"
    echo "SCORE:$best_score"
    echo "CONFIDENCE:$best_confidence"
}

# =============================================================================
# DÉBUG DU ROUTAGE
# =============================================================================
debug_routing() {
    echo -e "${CYAN}═══════════════════════════════════════════════════════════${NC}"
    echo -e "${CYAN}  NOVAHIZ ROUTER - Debug Mode${NC}"
    echo -e "${CYAN}═══════════════════════════════════════════════════════════${NC}"
    echo ""
    
    echo -e "${YELLOW}Configuration:${NC}"
    echo "  Config file: $CONFIG_FILE"
    [ -f "$CONFIG_FILE" ] && echo "  Status: ${GREEN}OK${NC}" || echo "  Status: ${RED}MISSING${NC}"
    echo ""
    
    echo -e "${YELLOW}Agents enregistrés:${NC}"
    jq -r '.agents | to_entries[] | "  \(.key) -> \(.value.domain) (\(.value.type))"' "$CONFIG_FILE"
    echo ""
    
    echo -e "${Yellow}Règles de routage:${NC}"
    jq -r '.routing_rules | to_entries[] | "  \(.key): \(.value)"' "$CONFIG_FILE"
    echo ""
    
    echo -e "${YELLOW}Derniers logs:${NC}"
    if [ -f "$LOG_FILE" ]; then
        tail -10 "$LOG_FILE" | sed 's/^/  /'
    else
        echo "  Aucun log"
    fi
    echo ""
}

# =============================================================================
# TEST DU ROUTAGE
# =============================================================================
test_routing() {
    local test_cases=(
        "Create a REST API with authentication"
        "Fix the database connection bug"
        "Design a modern UI for the dashboard"
        "Optimize the website performance"
        "Explain what is dependency injection"
        "Build a microservice architecture for e-commerce"
        "Setup CI/CD pipeline with GitHub Actions"
        "Implement real-time chat with websockets"
        "Review my code for security vulnerabilities"
        "Create a marketing strategy for my SaaS"
    )
    
    echo -e "${CYAN}═══════════════════════════════════════════════════════════${NC}"
    echo -e "${CYAN}  NOVAHIZ ROUTER - Test Suite${NC}"
    echo -e "${CYAN}═══════════════════════════════════════════════════════════${NC}"
    echo ""
    
    for test_case in "${test_cases[@]}"; do
        echo -e "${YELLOW}Test:${NC} $test_case"
        route_task "$test_case" "false" | grep -E "(Agent principal|Complexité|Mode)" | sed 's/^/  /'
        echo ""
    done
}

# =============================================================================
# USAGE
# =============================================================================
usage() {
    echo -e "${CYAN}═══════════════════════════════════════════════════════════${NC}"
    echo -e "${CYAN}  NOVAHIZ ROUTER${NC} - Intelligent Agent Routing System"
    echo -e "${CYAN}═══════════════════════════════════════════════════════════${NC}"
    echo ""
    echo "Usage: nv-route <command> [options]"
    echo ""
    echo "Commands:"
    echo "  route <task>      Route une tâche vers l'agent optimal"
    echo "  debug             Affiche les infos de debug"
    echo "  test              Exécute la suite de tests"
    echo "  list              Liste tous les agents"
    echo "  search <keyword>  Recherche des agents par keyword"
    echo ""
    echo "Options:"
    echo "  -v, --verbose     Mode verbeux"
    echo "  -h, --help        Affiche cette aide"
    echo ""
    echo "Examples:"
    echo "  nv-route route \"Build a REST API\""
    echo "  nv-route debug"
    echo "  nv-route test"
    echo "  nv-route list"
    echo "  nv-route search database"
    echo ""
}

# =============================================================================
# MAIN
# =============================================================================
main() {
    local command="${1:-help}"
    shift || true
    
    case "$command" in
        route)
            if [ -z "$1" ]; then
                log_error "Task required"
                echo "Usage: nv-route route <task>"
                exit 1
            fi
            local task="$*"
            local verbose="false"
            if [ "$1" = "-v" ] || [ "$1" = "--verbose" ]; then
                verbose="true"
            fi
            route_task "$task" "$verbose"
            ;;
        debug)
            debug_routing
            ;;
        test)
            test_routing
            ;;
        list)
            echo -e "${CYAN}Agents enregistrés:${NC}"
            jq -r '.agents | to_entries[] | "\(.key) | \(.value.domain) | \(.value.type) | \(.value.model)"' "$CONFIG_FILE" | column -t -s'|'
            ;;
        search)
            if [ -z "$1" ]; then
                log_error "Keyword required"
                echo "Usage: nv-route search <keyword>"
                exit 1
            fi
            local keyword="$1"
            echo -e "${CYAN}Agents pour le keyword: $keyword${NC}"
            jq -r --arg kw "$keyword" '.agents | to_entries[] | select(.value.keywords | any(. | test($kw; "i"))) | "\(.key) | \(.value.domain) | Score: \(.value.score)"' "$CONFIG_FILE" | column -t -s'|'
            ;;
        help|--help|-h)
            usage
            ;;
        *)
            log_error "Commande inconnue: $command"
            usage
            exit 1
            ;;
    esac
}

main "$@"
